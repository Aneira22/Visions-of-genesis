# ==============================
# Unity generated folders
# ==============================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
.utmp/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# ==============================
# IDE / Editor files
# ==============================
.vs/
.vscode/
.idea/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated meta files for the above
*.pidb.meta
*.pdb.meta
*.mdb.meta

# ==============================
# Build outputs / packages
# ==============================
*.apk
*.aab
*.unitypackage
*.app
*.ipa

# Unity crash reports
sysinfo.txt
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ==============================
# OS files
# ==============================
.DS_Store
Thumbs.db
